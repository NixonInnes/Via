<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local development feed (checked-in config, untracked packages) -->
    <add key="Via Local" value=".\.nupkg" />

    <!-- Public feed -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
